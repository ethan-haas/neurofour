# Frontend build-time config. Copy to `.env` for local dev, or set in the
# Cloudflare Pages project (Settings -> Environment variables) for production.
#
# Points the UI at the backend API. Local default is http://localhost:8000.
# In production set this to your deployed Render URL, e.g.
#   VITE_API_BASE=https://neurofour-api.onrender.com
VITE_API_BASE=http://localhost:8000
